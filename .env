# Microsoft Entra ID (Azure AD) config for MSAL
# Replace with your tenant/app details
VITE_AAD_CLIENT_ID=
VITE_AAD_AUTHORITY=

# Auth mode: ad | local
VITE_AUTH_MODE=local

# Optional group/role mapping (comma-separated Entra ID group IDs or roles)
VITE_AAD_ADMIN_GROUPS=
VITE_AAD_BIDDER_GROUPS=
VITE_AAD_OBSERVER_GROUPS=

# Local dev override when AD is not configured (Guest | Bidder | Observer | Admin)
VITE_DEV_ROLE=

# Auction API base URL
VITE_API_BASE_URL=http://localhost:5174
